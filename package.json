{
  "name": "bx-ai-plus-theme",
  "version": "0.1.0",
  "private": true,
  "description": "BX-AI+ — AI-centric Bootstrap 5 dashboard theme for Ortus Solutions BoxLang.",
  "license": "UNLICENSED",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "clean": "node tools/clean.mjs",
    "build:html": "eleventy",
    "build:css": "node tools/build-css.mjs",
    "build:js": "node tools/build-js.mjs",
    "build:assets": "node tools/copy-assets.mjs",
    "build": "npm-run-all clean -p build:html build:css build:js build:assets",
    "watch:html": "eleventy --watch",
    "watch:css": "node tools/build-css.mjs --watch",
    "watch:js": "node tools/build-js.mjs --watch",
    "watch:assets": "node tools/copy-assets.mjs --watch",
    "serve": "browser-sync start --server dist --files \"dist/**/*\" --no-notify --no-open",
    "dev": "npm-run-all build -p watch:html watch:css watch:js watch:assets serve",
    "tour": "node tools/screenshot-tour.mjs",
    "zip": "node tools/zip-dist.mjs",
    "handoff": "npm-run-all build tour zip"
  },
  "devDependencies": {
    "@11ty/eleventy": "^3.0.0",
    "autoprefixer": "^10.4.20",
    "bootstrap": "^5.3.6",
    "browser-sync": "^3.0.2",
    "chokidar": "^4.0.1",
    "cssnano": "^7.0.6",
    "esbuild": "^0.24.0",
    "fast-glob": "^3.3.2",
    "npm-run-all": "^4.1.5",
    "playwright": "^1.59.1",
    "postcss": "^8.4.47",
    "prismjs": "^1.30.0",
    "sass": "^1.80.6"
  },
  "dependencies": {
    "@fullcalendar/core": "^6.1.20",
    "@fullcalendar/daygrid": "^6.1.20",
    "@fullcalendar/interaction": "^6.1.20",
    "@fullcalendar/list": "^6.1.20",
    "@fullcalendar/timegrid": "^6.1.20",
    "apexcharts": "^3.54.0",
    "choices.js": "^11.0.2",
    "dragula": "^3.7.3",
    "dropzone": "^6.0.0-beta.2",
    "flatpickr": "^4.6.13",
    "fullcalendar": "^6.1.14",
    "gridjs": "^6.2.0",
    "inputmask": "^5.0.9",
    "jsvectormap": "^1.6.0",
    "leaflet": "^1.9.4",
    "lucide": "^0.462.0",
    "nouislider": "^15.7.1",
    "quill": "^1.3.7",
    "simple-datatables": "^9.0.3",
    "simplebar": "^6.2.7",
    "sweetalert2": "^11.14.5"
  }
}

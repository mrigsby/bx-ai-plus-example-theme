{#
  ----------------------------------------------------------------------------
  partials/chat-panel.njk — right-offcanvas AI chat.
  Receives queries from the command palette and the voice toast.
  ----------------------------------------------------------------------------
#}
{% seamBegin "CHAT_PANEL" %}
<div class="offcanvas offcanvas-end bx-chat-panel"
     tabindex="-1"
     id="bx-chat-panel"
     aria-labelledby="bx-chat-panel-title">

  <div class="offcanvas-header bx-chat-panel__header">
    <div class="bx-chat-panel__title-wrap">
      <span class="bx-chat-panel__avatar" aria-hidden="true">
        <i data-lucide="sparkles"></i>
      </span>
      <div>
        <div class="bx-chat-panel__title" id="bx-chat-panel-title">BX-AI Assistant</div>
        <div class="bx-chat-panel__status">
          <span class="bx-chat-panel__status-dot"></span>
          <span>Online · mock agent</span>
        </div>
      </div>
    </div>
    <div class="bx-chat-panel__header-actions">
      <button type="button" class="bx-btn-icon" data-bx-chat-panel-new aria-label="New conversation" title="New conversation">
        <i data-lucide="plus"></i>
      </button>
      <button type="button" class="btn-close" data-bs-dismiss="offcanvas" aria-label="Close"></button>
    </div>
  </div>

  <div class="bx-chat-panel__body" data-bx-chat-panel-body>
    {# Seed welcome message — rendered once on load #}
    <div class="bx-chat-msg bx-chat-msg--ai">
      <div class="bx-chat-msg__bubble">
        <p>Hi! I'm your BX-AI+ assistant. Ask me anything about this workspace — metrics, anomalies, recent activity, or to run a task.</p>
        <p class="bx-chat-msg__meta">Try <kbd>⌘K</kbd> anywhere to open the command bar.</p>
      </div>
    </div>
  </div>

  <div class="bx-chat-panel__composer">
    <form class="bx-chat-panel__form" data-bx-chat-panel-form autocomplete="off">
      <textarea
        class="bx-chat-panel__input"
        rows="1"
        placeholder="Message BX-AI…"
        data-bx-chat-panel-input
        aria-label="Message BX-AI"
      ></textarea>
      <div class="bx-chat-panel__composer-actions">
        <button type="button" class="bx-btn-icon" aria-label="Attach" title="Attach">
          <i data-lucide="paperclip"></i>
        </button>
        <button type="button" class="bx-btn-icon" aria-label="Voice" title="Voice" data-bx-voice-trigger>
          <i data-lucide="mic"></i>
        </button>
        <button type="submit" class="btn btn-primary bx-chat-panel__send" aria-label="Send">
          <i data-lucide="arrow-up"></i>
        </button>
      </div>
    </form>
    <p class="bx-chat-panel__hint">Mock responses for the theme demo — replies are canned.</p>
  </div>

</div>
{% seamEnd "CHAT_PANEL" %}

<h1>Create your workspace</h1>
<p class="bx-auth__lede">Get started with BX-AI+ in less than a minute.</p>

<form>
  <div class="row g-2 mb-3">
    <div class="col-6">
      <label class="form-label" for="bx-auth-fn">First name</label>
      <input type="text" class="form-control" id="bx-auth-fn" placeholder="Jane" autocomplete="given-name">
    </div>
    <div class="col-6">
      <label class="form-label" for="bx-auth-ln">Last name</label>
      <input type="text" class="form-control" id="bx-auth-ln" placeholder="Doe" autocomplete="family-name">
    </div>
  </div>
  <div class="mb-3">
    <label class="form-label" for="bx-auth-email">Work email</label>
    <input type="email" class="form-control" id="bx-auth-email" placeholder="you@company.com" autocomplete="username">
  </div>
  <div class="mb-3">
    <label class="form-label" for="bx-auth-pw">Password</label>
    <input type="password" class="form-control" id="bx-auth-pw" placeholder="At least 12 characters" autocomplete="new-password">
    <div class="form-text small">Use at least 12 characters with a mix of letters, numbers, and symbols.</div>
  </div>
  <div class="form-check mb-3">
    <input class="form-check-input" type="checkbox" id="bx-auth-tos">
    <label class="form-check-label small" for="bx-auth-tos">
      I agree to the <a href="#">Terms</a> and <a href="#">Privacy Policy</a>
    </label>
  </div>
  <button class="btn btn-primary" type="submit">Create account</button>
</form>

<div class="bx-auth__divider">or sign up with</div>
<div class="bx-auth__social">
  <button class="btn btn-outline-secondary" type="button"><i data-lucide="github"></i> GitHub</button>
  <button class="btn btn-outline-secondary" type="button"><i data-lucide="chrome"></i> Google</button>
</div>

<p class="bx-auth__alt">Already have an account? <a href="/auth/sign-in/">Sign in</a></p>

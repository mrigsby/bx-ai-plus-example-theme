<h1>Reset your password</h1>
<p class="bx-auth__lede">Enter the email on your account and we'll send a reset link.</p>

<form>
  <div class="mb-3">
    <label class="form-label" for="bx-auth-email">Email</label>
    <input type="email" class="form-control" id="bx-auth-email" placeholder="you@company.com" autocomplete="username">
  </div>
  <button class="btn btn-primary" type="submit">Send reset link</button>
</form>

<p class="bx-auth__alt">
  <a href="/auth/sign-in/"><i data-lucide="arrow-left" style="width:13px;height:13px;"></i> Back to sign in</a>
</p>

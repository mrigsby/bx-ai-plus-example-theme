title: Sign in
permalink: /auth/sign-in/index.html
---
<h1>Welcome back</h1>
<p class="bx-auth__lede">Sign in to your BX-AI+ workspace.</p>

<form>
  <div class="mb-3">
    <label class="form-label" for="bx-auth-email">Email</label>
    <input type="email" class="form-control" id="bx-auth-email" placeholder="you@company.com" autocomplete="username">
  </div>
  <div class="mb-3">
    <div class="d-flex justify-content-between align-items-center">
      <label class="form-label mb-0" for="bx-auth-pw">Password</label>
      <a href="/auth/forgot-password/" class="small text-decoration-none">Forgot?</a>
    </div>
    <input type="password" class="form-control mt-1" id="bx-auth-pw" placeholder="••••••••" autocomplete="current-password">
  </div>
  <div class="form-check mb-3">
    <input class="form-check-input" type="checkbox" id="bx-auth-remember" checked>
    <label class="form-check-label small" for="bx-auth-remember">Remember me on this device</label>
  </div>
  <button class="btn btn-primary" type="submit">Sign in</button>
</form>

<div class="bx-auth__divider">or continue with</div>
<div class="bx-auth__social">
  <button class="btn btn-outline-secondary" type="button"><i data-lucide="github"></i> GitHub</button>
  <button class="btn btn-outline-secondary" type="button"><i data-lucide="chrome"></i> Google</button>
</div>

<p class="bx-auth__alt">Don't have an account? <a href="/auth/sign-up/">Create one</a></p>

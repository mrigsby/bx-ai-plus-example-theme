---
layout: vertical.njk
title: Profile
pageTitle: Profile
pageSubtitle: Personal info, recent activity, and shared workspaces.
permalink: /pages/profile/index.html
breadcrumbs:
  - { label: "BX-AI+", href: "/" }
  - { label: "Pages" }
  - { label: "Profile" }
---

<div class="row g-3">

  <div class="col-12 col-xl-4">
    <div class="bx-widget text-center" style="padding-top:1.75rem;">
      <span class="bx-avatar" style="width:84px;height:84px;font-size:1.5rem;margin:0 auto 0.85rem;">
        <span class="bx-avatar__initials">{{ user.initials }}</span>
      </span>
      <h3 class="bx-widget__title" style="margin-bottom:0.25rem;">{{ user.name }}</h3>
      <p class="text-secondary mb-2">{{ user.role }} · {{ user.organization }}</p>
      <p class="text-secondary small mb-3">{{ user.email }}</p>
      <div class="d-flex gap-2 justify-content-center">
        <button class="btn btn-primary btn-sm">Edit profile</button>
        <button class="btn btn-outline-secondary btn-sm">Share</button>
      </div>
      <hr style="border-color:var(--bx-divider);">
      <div class="row text-center">
        <div class="col-4"><strong style="display:block;color:var(--bx-text-heading);">412</strong><span class="text-secondary small">Conversations</span></div>
        <div class="col-4"><strong style="display:block;color:var(--bx-text-heading);">14</strong><span class="text-secondary small">Agents</span></div>
        <div class="col-4"><strong style="display:block;color:var(--bx-text-heading);">9</strong><span class="text-secondary small">Projects</span></div>
      </div>
    </div>

    <div class="bx-widget mt-3">
      <div class="bx-widget__head"><div class="bx-widget__title-wrap"><h3 class="bx-widget__title">Workspaces</h3></div></div>
      <div class="bx-widget__body">
        <div class="d-flex align-items-center gap-3 py-2"><span class="bx-avatar bx-avatar--sm">OS</span><div style="flex:1;"><div style="font-weight:500;">Ortus Solutions</div><div class="text-secondary small">Owner · 14 members</div></div></div>
        <div class="d-flex align-items-center gap-3 py-2" style="border-top:1px solid var(--bx-divider);"><span class="bx-avatar bx-avatar--sm">HX</span><div style="flex:1;"><div style="font-weight:500;">Helix Labs</div><div class="text-secondary small">Editor · 6 members</div></div></div>
        <div class="d-flex align-items-center gap-3 py-2" style="border-top:1px solid var(--bx-divider);"><span class="bx-avatar bx-avatar--sm">WC</span><div style="flex:1;"><div style="font-weight:500;">Wattage Co.</div><div class="text-secondary small">Viewer · 22 members</div></div></div>
      </div>
    </div>
  </div>

  <div class="col-12 col-xl-8">
    <ul class="nav nav-tabs mb-3">
      <li class="nav-item"><button class="nav-link active" data-bs-toggle="tab" data-bs-target="#prof-overview">Overview</button></li>
      <li class="nav-item"><button class="nav-link" data-bs-toggle="tab" data-bs-target="#prof-activity">Activity</button></li>
      <li class="nav-item"><button class="nav-link" data-bs-toggle="tab" data-bs-target="#prof-projects">Projects</button></li>
    </ul>

    <div class="tab-content">
      <div class="tab-pane fade show active" id="prof-overview">
        <div class="bx-widget">
          <div class="bx-widget__head"><div class="bx-widget__title-wrap"><h3 class="bx-widget__title">About</h3></div></div>
          <div class="bx-widget__body">
            <p class="mb-3">Working on the BX-AI+ runtime and the surrounding tooling. Background: distributed systems, ML ops, BoxLang.</p>
            <dl class="row mb-0">
              <dt class="col-sm-3 text-secondary">Email</dt><dd class="col-sm-9">{{ user.email }}</dd>
              <dt class="col-sm-3 text-secondary">Role</dt><dd class="col-sm-9">{{ user.role }}</dd>
              <dt class="col-sm-3 text-secondary">Organization</dt><dd class="col-sm-9">{{ user.organization }}</dd>
              <dt class="col-sm-3 text-secondary">Joined</dt><dd class="col-sm-9">May 2024</dd>
              <dt class="col-sm-3 text-secondary">Timezone</dt><dd class="col-sm-9">America / Denver (MT)</dd>
            </dl>
          </div>
        </div>
      </div>

      <div class="tab-pane fade" id="prof-activity">
        <div class="bx-widget">
          <div class="bx-widget__body" style="padding:0.5rem 1.1rem;">
            <ul class="bx-activity">
              {% for a in dashboard.activity %}
              <li class="bx-activity__item"><span class="bx-activity__item-icon bx-activity__item-icon--{{ a.variant }}"><i data-lucide="{{ a.icon }}"></i></span><div class="bx-activity__item-body"><p class="bx-activity__item-text">{{ a.text }}</p><p class="bx-activity__item-meta">{{ a.actor }}</p></div><span class="bx-activity__item-time">{{ a.time }}</span></li>
              {% endfor %}
            </ul>
          </div>
        </div>
      </div>

      <div class="tab-pane fade" id="prof-projects">
        <div class="row g-3">
          {% for p in projects.projects %}{% if loop.index <= 4 %}
          <div class="col-12 col-md-6">
            <div class="bx-project-card bx-project-card--{{ p.tone }}">
              <div class="bx-project-card__head"><span class="bx-project-card__cat">{{ p.category }}</span><span class="bx-project-card__status bx-project-card__status--{{ p.tone }}" style="margin-left:auto;">{{ p.status | replace('-', ' ') }}</span></div>
              <h3 class="bx-project-card__name">{{ p.name }}</h3>
              <div class="bx-project-card__progress"><div class="bx-project-card__progress-row"><span><strong>{{ p.progress }}%</strong></span></div><div class="progress"><div class="progress-bar" style="width:{{ p.progress }}%"></div></div></div>
            </div>
          </div>
          {% endif %}{% endfor %}
        </div>
      </div>
    </div>
  </div>

</div>

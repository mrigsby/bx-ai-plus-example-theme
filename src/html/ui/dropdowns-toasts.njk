{# ---- Toast container ---- #}
<div class="toast-container position-fixed bottom-0 end-0 p-3" id="bx-toast-container" style="z-index: 1090;"></div>

<script>
// Tooltips & popovers are auto-initialized globally by core/tooltips.js.
// We only need the click handler for the toast demo — `window.bootstrap` is
// available by the time the user clicks (app.js loads at the end of <body>).
(function () {
  document.addEventListener("click", (e) => {
    const btn = e.target.closest("[data-bx-toast]");
    if (!btn) return;
    const variant = btn.getAttribute("data-bx-toast");
    const titles = { primary: "Notice", success: "Saved", warning: "Heads up", danger: "Failed" };
    const bgs    = { primary: "primary", success: "success", warning: "warning", danger: "danger" };
    const root = document.getElementById("bx-toast-container");
    const t = document.createElement("div");
    t.className = `toast text-bg-${bgs[variant]}`;
    t.role = "alert";
    t.innerHTML = `
      <div class="toast-header text-bg-${bgs[variant]}" style="border:0;">
        <strong class="me-auto">${titles[variant]}</strong>
        <small>now</small>
        <button type="button" class="btn-close ms-2" data-bs-dismiss="toast" aria-label="Close"></button>
      </div>
      <div class="toast-body">This is a ${variant} toast — ${variant === "danger" ? "something went wrong" : "all good"}.</div>`;
    root.appendChild(t);
    new bootstrap.Toast(t, { delay: 4000 }).show();
    t.addEventListener("hidden.bs.toast", () => t.remove());
  });
})();
</script>
